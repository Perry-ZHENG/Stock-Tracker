<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.example.stock-agent.worker</string>

  <key>ProgramArguments</key>
  <array>
    <string>${STOCK_AGENT_BIN}</string>
    <string>worker</string>
    <string>--interval-sec</string>
    <string>${STOCK_AGENT_INTERVAL_SEC}</string>
  </array>

  <key>WorkingDirectory</key>
  <string>${STOCK_AGENT_WORKDIR}</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>STOCK_AGENT_WORKDIR</key>
    <string>${STOCK_AGENT_WORKDIR}</string>
    <key>STOCK_AGENT_CONFIG</key>
    <string>${STOCK_AGENT_CONFIG}</string>
    <key>TWELVE_DATA_API_KEY</key>
    <string>${TWELVE_DATA_API_KEY}</string>
    <key>GEMINI_API_KEY</key>
    <string>${GEMINI_API_KEY}</string>
    <key>OPENROUTER_API_KEY</key>
    <string>${OPENROUTER_API_KEY}</string>
    <key>TELEGRAM_BOT_TOKEN</key>
    <string>${TELEGRAM_BOT_TOKEN}</string>
    <key>NEWS_API_KEY</key>
    <string>${NEWS_API_KEY}</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>${STOCK_AGENT_LOG_DIR}/worker.out.log</string>
  <key>StandardErrorPath</key>
  <string>${STOCK_AGENT_LOG_DIR}/worker.err.log</string>
</dict>
</plist>
